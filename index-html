<!DOCTYPE html>
<html lang="ro">
<head><meta charset="UTF-8"><title>Tool AI</title></head>
<body style="background:#0f172a;color:white;font-family:Arial;">
<h1>Tool AI</h1>
<select id="type">
<option>Mesaj</option>
<option>Idee</option>
<option>Nume</option>
</select>
<input id="input" placeholder="Scrie ceva...">
<button onclick="gen()">Generează</button>
<p id="out"></p>
<script>
function gen(){
 let t=document.getElementById('type').value;
 let i=document.getElementById('input').value;
 document.getElementById('out').innerText = t+": "+i+" (generat)";
}
</script>
</body>
</html>


